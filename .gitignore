*_override.tf.json
.terraformrc
terraform.rc
terraform/**/backend.hcl

# --- Chaves e segredos -------------------------------------------------------
*.key
*.pem
id_ed25519
id_rsa
!*.pub
ssh-key-*.pem

# --- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- Helm --------------------------------------------------------------------
charts/*/charts/
*.tgz

# --- Logs --------------------------------------------------------------------
*.log

# --- Misc --------------------------------------------------------------------
*.bak
*.tmp
*.pdf
*.zip

# --- AWS CLI local (fora do escopo do projeto) ------------------------------
aws/

__pycache__/
